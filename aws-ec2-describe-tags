#!/bin/bash -e

# Describe AWS EC2 tags for a given resource ID.
# Outputs a compact JSON array of {Key, Value} objects to stdout
# and saves the same to /tmp/tags-<resource_id>.json.
#
# Usage: aws-ec2-describe-tags <resource_id>
# Example: aws-ec2-describe-tags i-0abc123def456

usage="$0 resource_id"

# Validate that exactly one argument (resource ID) is provided
if [[ $# -ne 1 ]]; then
  echo 'ERROR: Invalid usage'
  echo $usage
  exit 1
fi

resource_id=$1

# Fetch tags for the resource, extract Key/Value pairs, and save to a temp file
aws ec2 describe-tags --filters="Name=resource-id,Values=$resource_id" | jq -c '.[] | map({Key,Value})' | tee /tmp/tags-${resource_id}.json
